{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Slang Debug Build",
            "type": "shell",
            "group": {
                "kind": "build",
            },
            "command": "python",
            "args": [
                "${workspaceFolder}/build_slang.py",
                "${workspaceFolder}",
                "Debug",
                "${workspaceFolder}/target/debug",
            ],
        },
        {
            "label": "Slang Release Build",
            "type": "shell",
            "group": {
                "kind": "build",
            },
            "command": "python",
            "args": [
                "${workspaceFolder}/build_slang.py",
                "${workspaceFolder}",
                "Release",
                "${workspaceFolder}/target/release",
            ]
        }
    ]
}